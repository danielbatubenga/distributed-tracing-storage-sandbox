{
  "uid": "series-overview",
  "title": "AGT - Criação de Séries",
  "description": "Visibilidade completa do fluxo de criação de séries: sucesso, falhas, onde falham e porquê",
  "tags": [
    "facturacao",
    "series",
    "sre"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 4,
      "type": "gauge",
      "title": "Taxa de Sucesso (%)",
      "gridPos": {
        "w": 6,
        "h": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(series_total{module=\"facturacao-ms-core\"}[5m])) / (sum(rate(series_total{module=\"facturacao-ms-core\"}[5m])) + (sum(rate(series_failed_total{module=\"facturacao-ms-core\"}[5m])) - sum(rate(series_validation_failed_total{module=\"facturacao-ms-core\"}[5m]))))) * 100",
          "legendFormat": "Sucesso %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "type": "piechart",
      "title": "Distribuição de Erros por Tipo (Última 1h)",
      "gridPos": {
        "w": 6,
        "h": 6,
        "x": 18,
        "y": 0
      },
      "id": 52904,
      "targets": [
        {
          "expr": "sum by (error_type) (increase(series_failed_total{module=\"facturacao-ms-core\"}[1h]))",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Taxa de Criação vs Falhas (por segundo)",
      "gridPos": {
        "w": 12,
        "h": 8,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(series_total{module=\"facturacao-ms-core\"}[5m]))",
          "legendFormat": "Criações/s"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(series_failed_total{module=\"facturacao-ms-core\"}[5m]))",
          "legendFormat": "Falhas/s"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(series_validation_failed_total{module=\"facturacao-ms-core\"}[5m]))",
          "legendFormat": "Validação Falhou/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Logs de Séries (traceId + nif + seriesCode)",
      "description": "Clique no traceId para abrir o trace completo no Tempo",
      "gridPos": {
        "w": 24,
        "h": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{app=\"facturacao-ms-core\"} |~ \"(?i)(series|serial number)\" |= \"$search_nif\" | json | line_format \"[{{.level}}] [traceId={{.traceId}}] {{.message}}\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "prettifyLogMessage": false,
        "enableLogDetails": true
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Séries Criadas (última 1h)",
      "gridPos": {
        "w": 6,
        "h": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(series_total{module=\"facturacao-ms-core\"}[1h]))",
          "legendFormat": "Criadas"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Falhas (última 1h)",
      "gridPos": {
        "w": 6,
        "h": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(series_failed_total{module=\"facturacao-ms-core\"}[1h]))",
          "legendFormat": "Falhas"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Falhas de Validação (última 1h)",
      "gridPos": {
        "w": 12,
        "h": 6,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(series_validation_failed_total{module=\"facturacao-ms-core\"}[1h]))",
          "legendFormat": "Validação Falhou"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Latência P95 (série.create)",
      "gridPos": {
        "w": 12,
        "h": 6,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(series_creation_duration_seconds_bucket{module=\"facturacao-ms-core\"}[5m]))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latência de Criação (P50 / P95 / P99)",
      "gridPos": {
        "w": 12,
        "h": 8,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, rate(series_creation_duration_seconds_bucket{module=\"facturacao-ms-core\"}[5m]))",
          "legendFormat": "P50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(series_creation_duration_seconds_bucket{module=\"facturacao-ms-core\"}[5m]))",
          "legendFormat": "P95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, rate(series_creation_duration_seconds_bucket{module=\"facturacao-ms-core\"}[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "JVM - Heap Usage",
      "gridPos": {
        "w": 8,
        "h": 8,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"facturacao-ms-core\"} / jvm_memory_max_bytes{area=\"heap\",job=\"facturacao-ms-core\"} * 100",
          "legendFormat": "Heap %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HikariCP - Conexões Oracle",
      "gridPos": {
        "w": 8,
        "h": 8,
        "x": 8,
        "y": 20
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hikaricp_connections_active{job=\"facturacao-ms-core\"}",
          "legendFormat": "Activas"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hikaricp_connections_idle{job=\"facturacao-ms-core\"}",
          "legendFormat": "Idle"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hikaricp_connections_max{job=\"facturacao-ms-core\"}",
          "legendFormat": "Máximo"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Requests (por status)",
      "gridPos": {
        "w": 8,
        "h": 8,
        "x": 16,
        "y": 20
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"facturacao-ms-core\"}[5m])) by (status, uri)",
          "legendFormat": "{{status}} {{uri}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "search_nif",
        "label": "Pesquisar NIF",
        "type": "textbox",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "options": [
          {
            "selected": true,
            "text": "",
            "value": ""
          }
        ]
      }
    ]
  }
}